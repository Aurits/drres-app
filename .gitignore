# ══════════════════════════════════════════════
# Dr-RES — Root .gitignore
# Covers frontend (Next.js) + backend (Node.js)
# ══════════════════════════════════════════════

# ─── Dependencies ─────────────────────────────
node_modules/
.pnp/
.pnp.js
.yarn/

# ─── Build Output ─────────────────────────────
.next/
out/
dist/
build/
*.tsbuildinfo

# ─── Environment Variables ────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ─── Database ─────────────────────────────────
*.sqlite
*.sqlite3
*.db
prisma/migrations/*.sql.bak

# ─── IDE & Editor ─────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ─── OS Files ─────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# ─── Logs ─────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ─── Test & Coverage ─────────────────────────
coverage/
.nyc_output/
*.lcov

# ─── Next.js Specific ────────────────────────
.next/
.vercel/
.turbo/
next-env.d.ts

# ─── Uploaded Files & Temp ────────────────────
uploads/
temp/
tmp/
*.tmp
*.bak

# ─── AI & Vectors ────────────────────────────
# Large model files, vector indexes
*.bin
*.onnx
*.pt
*.safetensors
vector_store/
embeddings_cache/

# ─── Secrets & Keys ──────────────────────────
*.pem
*.key
*.cert
*.crt
service-account*.json
